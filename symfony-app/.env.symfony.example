# Symfony stack environment variables — copy to .env.local for local dev
# NEVER commit .env.local or any file with real secrets.
#
# For Docker deployment: copy to .env at the repo root and set values there.
# docker-compose.yml reads variables from the root .env file.

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=prod
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME_32_CHAR_HEX_STRING

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_DB=styll
POSTGRES_USER=styll
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Used by Symfony when running outside Docker:
DATABASE_URL=postgresql://styll:CHANGE_ME@localhost:5432/styll?serverVersion=16&charset=utf8

# ─── JWT Authentication ────────────────────────────────────────────────────────
# Generate RSA key pair:
#   symfony console lexik:jwt:generate-keypair
# Or manually:
#   openssl genpkey -algorithm RSA -out config/jwt/private.pem -aes256 -pass pass:PASSPHRASE
#   openssl pkey -in config/jwt/private.pem -out config/jwt/public.pem -pubout -passin pass:PASSPHRASE
JWT_PASSPHRASE=CHANGE_ME_JWT_PASSPHRASE
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# ─── Mercure (Realtime / SSE — replaces Supabase Realtime) ───────────────────
# Shared secret used to sign Mercure JWTs (publisher + subscriber).
# Generate: openssl rand -base64 32
MERCURE_JWT_SECRET=CHANGE_ME_MERCURE_SECRET

# Internal URL (Symfony → Mercure hub, used to publish updates)
MERCURE_URL=http://mercure/.well-known/mercure

# Public URL the browser connects to
MERCURE_PUBLIC_URL=http://localhost:3001/.well-known/mercure

# Allowed CORS origins for Mercure hub
MERCURE_CORS_ORIGINS=http://localhost:3000

# ─── WhatsApp / SMS (Twilio) ───────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# TWILIO_AUTH_TOKEN=CHANGE_ME
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_SMS_FROM=+1XXXXXXXXXX

# ─── Email (Symfony Mailer + Resend) ──────────────────────────────────────────
# MAILER_DSN=resend+api://CHANGE_ME@default
# MAILER_FROM=noreply@yourdomain.com

# ─── Stripe (v2 — payments) ───────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_CHANGE_ME
# STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── Object Storage (MinIO self-hosted or AWS S3) ────────────────────────────
# Replaces Supabase Storage
# STORAGE_ENDPOINT=http://minio:9000
# STORAGE_KEY=CHANGE_ME
# STORAGE_SECRET=CHANGE_ME
# STORAGE_BUCKET=styll-uploads
# STORAGE_REGION=eu-west-1

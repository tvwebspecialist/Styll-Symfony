# Styll Symfony production environment template.
# Copy to the real production environment file on the VPS and replace every
# CHANGE_ME_* placeholder there. Never commit real production values.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
APP_SHARE_DIR=var/share
DEFAULT_URI=https://CHANGE_ME_PRODUCTION_API_DOMAIN

# PostgreSQL container bootstrap.
POSTGRES_DB=styll
POSTGRES_USER=styll
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48

# Symfony DB URL for non-container CLI usage. In Docker, docker-compose.yml
# builds DATABASE_URL for the php service from POSTGRES_* variables.
DATABASE_URL=postgresql://styll:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/styll?serverVersion=16&charset=utf8

# JWT authentication. Generate the real keypair only on the VPS.
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Mercure realtime hub.
MERCURE_URL=http://mercure/.well-known/mercure
MERCURE_PUBLIC_URL=https://CHANGE_ME_PRODUCTION_API_DOMAIN/.well-known/mercure
MERCURE_JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
MERCURE_CORS_ORIGINS=https://CHANGE_ME_PRODUCTION_FRONTEND_DOMAIN

# Browser/API allowed origins. Use comma-separated exact origins.
CORS_ALLOW_ORIGIN=https://styll.it,https://www.styll.it,https://CHANGE_ME_VERCEL_PRODUCTION_DOMAIN

# Backup API tokens.
# BACKUP_REPORT_TOKEN: shared with ~/scripts/backup-postgres.sh on the VPS.
# ADMIN_API_TOKEN: shared with the Next.js server-side proxy (SYMFONY_ADMIN_API_TOKEN on Vercel).
# Generate both with: openssl rand -hex 32
BACKUP_REPORT_TOKEN=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
ADMIN_API_TOKEN=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# Backblaze B2 credentials for backup verify (restore test).
# Same bucket/keys as in ~/backups/b2.env on the VPS.
BACKUP_B2_KEY_ID=CHANGE_ME_B2_KEY_ID
BACKUP_B2_APPLICATION_KEY=CHANGE_ME_B2_APPLICATION_KEY
BACKUP_B2_BUCKET=CHANGE_ME_B2_BUCKET_NAME
BACKUP_B2_REMOTE_PREFIX=postgres

# Reverse proxy hardening. Replace with the VPS proxy CIDR/IP.
TRUSTED_PROXIES=CHANGE_ME_REVERSE_PROXY_IP_OR_CIDR
TRUSTED_HOSTS='^CHANGE_ME_PRODUCTION_API_DOMAIN$'

# Optional providers for later phases. Leave unset until the feature is enabled.
MAILER_DSN=CHANGE_ME_ONLY_WHEN_EMAIL_IS_ENABLED
MAILER_FROM=noreply@CHANGE_ME_DOMAIN
STRIPE_SECRET_KEY=CHANGE_ME_ONLY_WHEN_PAYMENTS_ARE_ENABLED
STRIPE_WEBHOOK_SECRET=CHANGE_ME_ONLY_WHEN_PAYMENTS_ARE_ENABLED
TWILIO_ACCOUNT_SID=CHANGE_ME_ONLY_WHEN_SMS_OR_WHATSAPP_IS_ENABLED
TWILIO_AUTH_TOKEN=CHANGE_ME_ONLY_WHEN_SMS_OR_WHATSAPP_IS_ENABLED
TWILIO_WHATSAPP_FROM=CHANGE_ME_ONLY_WHEN_SMS_OR_WHATSAPP_IS_ENABLED
TWILIO_SMS_FROM=CHANGE_ME_ONLY_WHEN_SMS_IS_ENABLED
STORAGE_ENDPOINT=CHANGE_ME_ONLY_WHEN_OBJECT_STORAGE_IS_ENABLED
STORAGE_KEY=CHANGE_ME_ONLY_WHEN_OBJECT_STORAGE_IS_ENABLED
STORAGE_SECRET=CHANGE_ME_ONLY_WHEN_OBJECT_STORAGE_IS_ENABLED
STORAGE_BUCKET=styll-uploads
STORAGE_REGION=eu-west-1

{
  "name": "styll",
  "private": true,
  "version": "0.0.1",
  "description": "Styll — SaaS platform di retention per barbieri",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "type-check": "pnpm --filter web type-check",
    "test:security:unit": "pnpm --filter web test:security:unit",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:ui": "pnpm --filter web test:e2e:ui",
    "test:e2e:ci": "pnpm --filter web test:e2e:ci"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "js-cookie": "3.0.8"
    }
  }
}

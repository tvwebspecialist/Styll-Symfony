# Styll — Environment Variables
# Copy this file to apps/web/.env.local and fill in your values

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Styll

# ── Stripe (v2) ───────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (email) ────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...

# ── Twilio (SMS/WhatsApp) ─────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+39...

# ── Meta WhatsApp Webhook (vNext inbox) ───────────────────────────────────────
# META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=choose-a-random-string
# META_APP_SECRET=your-meta-app-secret
# META_WHATSAPP_ACCESS_TOKEN=EAAG...
# META_WHATSAPP_GRAPH_API_VERSION=v23.0

# ── OTP Email (F-13) ──────────────────────────────────────────────────────────
# Pepper HMAC-SHA-256 per i codici OTP email. Obbligatorio in produzione.
# Genera con: openssl rand -hex 32
EMAIL_VERIFICATION_OTP_PEPPER=

# ── Sentry (monitoring errori — solo produzione) ──────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── PostHog ───────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

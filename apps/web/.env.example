# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
SUPABASE_SECRET_KEY=<your-secret-key>

# App
# Must match the Site URL configured in Supabase Dashboard > Authentication > URL Configuration.
# Without this, resolveOrigin() may fall back to localhost in server-side environments,
# producing a redirectTo not in the Supabase allow-list and breaking OAuth callbacks.
NEXT_PUBLIC_APP_URL=https://styll.it
NEXT_PUBLIC_APP_NAME=Styll
NEXT_PUBLIC_PWA_BASE_DOMAIN=styll.it

# Email (Resend)
RESEND_API_KEY=re_<your-resend-key>

# Meta WhatsApp Inbox manual reply
# Required to send manual outbound replies from Marketing > Messaggi > Inbox.
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_GRAPH_API_VERSION=v23.0
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=

# Inbox AI draft provider
# Safe default is "fake". Set to "anthropic" only when ANTHROPIC_API_KEY is configured.
INBOX_AI_PROVIDER=fake
ANTHROPIC_API_KEY=

# ─── Web Push / VAPID ────────────────────────────────────────────────────────
# Genera con: node -e "const wp = require('web-push'); const k = wp.generateVAPIDKeys(); console.log(k)"
# Lascia tutte e tre le variabili vuote per disabilitare le push in questo ambiente.
# Compilarne solo una parte e' considerato misconfigured e viene rifiutato a runtime.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=
# Secret per autenticare il cron endpoint
CRON_SECRET=

# ─── Symfony backend API (VPS Hetzner) ───────────────────────────────────────
# Base URL of the Symfony API (no trailing slash)
SYMFONY_API_URL=https://api.styll.it
# Staff dashboard context keeps Supabase by default.
# Set to true only after a confirmed Supabase session -> Symfony JWT bridge,
# or after the staff login flow has been migrated directly to Symfony.
NEXT_PUBLIC_USE_SYMFONY_STAFF_CONTEXT=false
# Static token shared with Symfony ADMIN_API_TOKEN env var.
# Generate with: openssl rand -hex 32
SYMFONY_ADMIN_API_TOKEN=

# ─── OTP Email Verification (F-13) ───────────────────────────────────────────
# Pepper HMAC-SHA-256 per hashare i codici OTP email prima del salvataggio.
# Genera con: openssl rand -hex 32
# OBBLIGATORIO in produzione. Assenza causa fail-closed al primo tentativo OTP.
EMAIL_VERIFICATION_OTP_PEPPER=

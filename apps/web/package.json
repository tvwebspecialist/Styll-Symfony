{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"require('node:fs').rmSync('.next',{ recursive: true, force: true })\" && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "type-check": "node -e \"require('node:fs').rmSync('.next-typecheck',{ recursive: true, force: true })\" && NEXT_DIST_DIR=.next-typecheck NODE_ENV=production next typegen && tsc --noEmit --project tsconfig.typecheck.json",
    "test:security:unit": "node --experimental-strip-types --test tests/unit/bearer-secret.test.mjs tests/unit/endpoint-ownership.test.mjs tests/unit/magic-wand.test.mjs tests/unit/public-error.test.mjs",
    "test:inbox:unit": "node --experimental-strip-types --test tests/unit/inbox-helpers.test.mjs tests/unit/inbox-queries.test.mjs tests/unit/manual-whatsapp-reply-core.test.mjs tests/unit/message-delivery.test.mjs tests/unit/messaging-policy.test.mjs tests/unit/meta-whatsapp-adapter.test.mjs tests/unit/meta-whatsapp-signature.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "playwright test --reporter=github"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.57.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@vercel/analytics": "^2.0.1",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.3",
    "posthog-js": "^1.396.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@next/env": "16.2.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.61.1",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  }
}
